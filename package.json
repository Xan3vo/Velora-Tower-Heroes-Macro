{
  "name": "tower-heroes-macro",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "pack": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.towerheroes.macro",
    "productName": "Tower Heroes Macro",
    "files": [
      "**/*",
      "!dist/**",
      "!CLAUDE.md",
      "!.claude/**",
      "!README.md",
      "!LICENSE",
      "!.gitignore",
      "!*.log"
    ],
    "asar": false,
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "Logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
